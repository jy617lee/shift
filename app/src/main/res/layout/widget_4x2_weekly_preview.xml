<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E3932"
    android:orientation="vertical">

    <!-- Header: 62dp, dark forest green -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:gravity="top|center_horizontal"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="18dp">

        <!-- Left: day label + large date, white -->
        <LinearLayout
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:gravity="top|center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="토"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-2dp"
                android:text="13"
                android:textColor="#FFFFFF"
                android:textSize="28sp" />

        </LinearLayout>

        <!-- Spacer 8dp -->
        <TextView
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Divider: rgba(255,255,255,0.15) -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#26FFFFFF" />

        <!-- Spacer 8dp -->
        <TextView
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Right: work time, top-offset white -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="11dp"
            android:gravity="center"
            android:text="17:00-22:30"
            android:textColor="#FFFFFF"
            android:textSize="29sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Wave divider: 24dp, dark green bg + white wave -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#1E3932">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/widget_wave_divider" />

    </FrameLayout>

    <!-- White grid section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:paddingLeft="9dp"
        android:paddingRight="9dp"
        android:paddingBottom="31dp">

        <!-- 목 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="목"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="정규휴일"
                android:textColor="#6B6760"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- 금 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="금"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="15:00"
                android:textColor="#6B6760"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="20:30"
                android:textColor="#6B6760"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- 토 (today) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_today_badge_circle"
                android:padding="4dp"
                android:text="토"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="17:00"
                android:textColor="#00704A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="22:30"
                android:textColor="#00704A"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 일 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="일"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="17:00"
                android:textColor="#6B6760"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="22:30"
                android:textColor="#6B6760"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- 월 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="월"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="연차휴가"
                android:textColor="#6B6760"
                android:textSize="15sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
