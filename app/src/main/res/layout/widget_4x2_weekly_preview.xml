<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E3932"
    android:orientation="vertical">

    <!-- Header: 62dp, dark forest green -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="14dp"
        android:paddingRight="14dp">

        <!-- Left: day label (50% white) + large date -->
        <LinearLayout
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="토"
                android:textColor="#80FFFFFF"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="13"
                android:textColor="#FFFFFF"
                android:textSize="29sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Spacer 8dp -->
        <TextView
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Divider: rgba(255,255,255,0.15) -->
        <TextView
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:background="#26FFFFFF" />

        <!-- Spacer 8dp -->
        <TextView
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <!-- Right: work time, centered, mint color -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="17:00-22:30"
            android:textColor="#D4E9E2"
            android:textSize="25sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Wave divider: 24dp, dark green bg + white wave -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="#1E3932">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/widget_wave_divider" />

    </FrameLayout>

    <!-- White grid section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="44dp">

        <!-- 목 11 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="11 (목)"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="정규휴일"
                android:textColor="#9A9488"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 금 12 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="12 (금)"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="15:00"
                android:textColor="#9A9488"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="20:30"
                android:textColor="#9A9488"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 토 13 (today) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_today_badge"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="13 (토)"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="17:00"
                android:textColor="#00704A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="22:30"
                android:textColor="#00704A"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 일 14 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="14 (일)"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="17:00"
                android:textColor="#9A9488"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="22:30"
                android:textColor="#9A9488"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- 월 15 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="15 (월)"
                android:textColor="#1E3932"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="연차휴가"
                android:textColor="#9A9488"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
